{
  "download_dir": {
    "type": "string",
    "description": "漫画下载目录",
    "hint": "下载的漫画将保存到此目录，可使用相对路径或绝对路径",
    "default": "./downloads"
  },
  "image_suffix": {
    "type": "string",
    "description": "图片格式",
    "hint": "下载图片的格式转换",
    "default": ".jpg",
    "options": [
      ".jpg",
      ".png",
      ".webp"
    ]
  },
  "client_type": {
    "type": "string",
    "description": "客户端类型",
    "hint": "api模式使用移动端API兼容性好，html模式使用网页端效率高但限制IP地区",
    "default": "api",
    "options": [
      "api",
      "html"
    ]
  },
  "use_proxy": {
    "type": "bool",
    "description": "是否使用代理",
    "hint": "某些地区可能需要代理才能访问JM网站",
    "default": false
  },
  "proxy_url": {
    "type": "string",
    "description": "代理服务器地址",
    "hint": "格式: http://host:port 或 socks5://host:port",
    "default": ""
  },
  "max_concurrent_photos": {
    "type": "int",
    "description": "最大并发章节数",
    "hint": "同时下载的章节数量，建议3-5",
    "default": 3
  },
  "max_concurrent_images": {
    "type": "int",
    "description": "最大并发图片数",
    "hint": "每个章节同时下载的图片数量，建议5-10",
    "default": 5
  },
  "pack_format": {
    "type": "string",
    "description": "打包格式",
    "hint": "下载完成后的打包格式",
    "default": "zip",
    "options": [
      "zip",
      "pdf",
      "none"
    ]
  },
  "pack_password": {
    "type": "string",
    "description": "打包密码",
    "hint": "为ZIP或PDF设置密码，留空则不加密",
    "default": ""
  },
  "filename_show_password": {
    "type": "bool",
    "description": "文件名显示密码",
    "hint": "开启后在文件名末尾添加 #PWxxx 提示（仅当设置了密码时生效）",
    "default": false
  },
  "auto_delete_after_send": {
    "type": "bool",
    "description": "发送后自动删除",
    "hint": "发送文件后是否自动删除本地文件以节省空间",
    "default": true
  },
  "send_cover_preview": {
    "type": "bool",
    "description": "发送封面预览",
    "hint": "下载前是否发送漫画封面图片预览",
    "default": true
  },
  "cover_recall_enabled": {
    "type": "bool",
    "description": "封面消息自动撤回",
    "hint": "开启后封面预览消息会自动撤回（仅支持 QQ/NapCat 平台）",
    "default": false
  },
  "auto_recall_enabled": {
    "type": "bool",
    "description": "文件消息自动撤回",
    "hint": "发送文件后自动撤回（仅支持 QQ/NapCat 平台）",
    "default": false
  },
  "auto_recall_delay": {
    "type": "int",
    "description": "撤回延迟（秒）",
    "hint": "发送后多少秒自动撤回，建议30-120",
    "default": 60
  },
  "enabled_groups": {
    "type": "string",
    "description": "启用的群列表",
    "hint": "以逗号分隔的群号列表，留空则所有群都启用",
    "default": ""
  },
  "admin_only": {
    "type": "bool",
    "description": "仅管理员可用",
    "hint": "开启后只有管理员列表中的用户才能使用插件",
    "default": false
  },
  "admin_list": {
    "type": "string",
    "description": "管理员用户ID列表",
    "hint": "以逗号分隔的用户ID列表，这些用户拥有管理员权限",
    "default": ""
  },
  "jm_username": {
    "type": "string",
    "description": "JM账号用户名",
    "hint": "填写后可自动登录，解锁收藏夹等功能（可选）",
    "default": ""
  },
  "jm_password": {
    "type": "string",
    "description": "JM账号密码",
    "hint": "配合用户名使用，支持自动登录（可选）",
    "default": ""
  },
  "smtp_enabled": {
    "type": "bool",
    "description": "启用SMTP邮箱发送",
    "hint": "开启后可使用 /jmemail 和 /jmcemail 命令发送加密附件到邮箱",
    "default": false
  },
  "smtp_host": {
    "type": "string",
    "description": "SMTP服务器地址",
    "hint": "例如 smtp.qq.com、smtp.gmail.com",
    "default": ""
  },
  "smtp_port": {
    "type": "int",
    "description": "SMTP端口",
    "hint": "SSL 常用 465，STARTTLS 常用 587",
    "default": 465
  },
  "smtp_use_ssl": {
    "type": "bool",
    "description": "SMTP使用SSL",
    "hint": "通常与 465 端口配合使用，建议与 STARTTLS 二选一",
    "default": true
  },
  "smtp_use_tls": {
    "type": "bool",
    "description": "SMTP使用STARTTLS",
    "hint": "通常与 587 端口配合使用，建议与 SSL 二选一",
    "default": false
  },
  "smtp_username": {
    "type": "string",
    "description": "SMTP登录用户名",
    "hint": "通常为发件邮箱地址",
    "default": ""
  },
  "smtp_password": {
    "type": "string",
    "description": "SMTP登录密码或授权码",
    "hint": "请填写邮箱服务商提供的 SMTP 密码或授权码",
    "default": ""
  },
  "smtp_from_email": {
    "type": "string",
    "description": "发件邮箱地址",
    "hint": "邮件发件人地址",
    "default": ""
  },
  "smtp_from_name": {
    "type": "string",
    "description": "发件人名称",
    "hint": "邮件中显示的发件人名称",
    "default": "JM-Cosmos II"
  },
  "email_subject_template": {
    "type": "string",
    "description": "邮件主题模板",
    "hint": "支持 {album_id}、{title}、{recipient}、{pack_format} 等变量",
    "default": "[JM-Cosmos II] {title} ({album_id})"
  },
  "email_body_template": {
    "type": "text",
    "description": "邮件正文模板",
    "hint": "支持 {album_id}、{title}、{author}、{image_count}、{photo_count}、{pack_format}、{encrypted}、{recipient}",
    "default": "下载任务已完成。\n\n标题: {title}\n本子ID: {album_id}\n作者: {author}\n章节数: {photo_count}\n图片数: {image_count}\n打包格式: {pack_format}\n已加密: {encrypted}\n收件人: {recipient}"
  },
  "email_max_attachment_mb": {
    "type": "int",
    "description": "邮箱附件大小限制(MB)",
    "hint": "超过该大小将拒绝发送，以避免 SMTP 附件超限",
    "default": 20
  },
  "email_send_timeout": {
    "type": "int",
    "description": "邮箱发送超时时间(秒)",
    "hint": "SMTP 连接、登录与发送的超时时间",
    "default": 60
  },
  "search_page_size": {
    "type": "int",
    "description": "搜索结果每页数量",
    "hint": "每次搜索返回的结果数量",
    "default": 5
  },
  "daily_download_limit": {
    "type": "int",
    "description": "每日下载次数限制",
    "hint": "每个用户每天最多下载次数，0 表示不限制",
    "default": 0
  },
  "debug_mode": {
    "type": "bool",
    "description": "调试模式",
    "hint": "开启后会输出详细的调试日志",
    "default": false
  }
}
